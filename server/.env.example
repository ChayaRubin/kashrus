# Copy to .env and fill in real values.
# Required for "too many connections" on Clever Cloud: add connection_limit to DATABASE_URL.

PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&connection_limit=2
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your-secret-here

# Optional: email, Cloudinary, etc.
# EMAIL_USER=
# EMAIL_PASS=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
